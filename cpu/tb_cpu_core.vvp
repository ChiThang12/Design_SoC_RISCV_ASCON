TD_tb_riscv_soc_top_cached.display_stats ;
    %vpi_call 4 69 "$display", "========================================";
    %vpi_call 4 70 "$display", "Cache Statistics at time %0t", $time;
    %vpi_call 4 71 "$display", "========================================";
    %vpi_call 4 72 "$display", "ICache Hits:    %0d", v013AD5C0_0;
    %vpi_call 4 73 "$display", "ICache Misses:  %0d", v013ADA38_0;
    %load/v 8, v013AD5C0_0, 32;
    %mov 40, 0, 1;
    %load/v 41, v013ADA38_0, 32;
    %mov 73, 0, 1;
    %add 8, 41, 33;
    %cmp/u 0, 8, 33;
    %jmp/0xz  T_0.0, 5;
    %load/v 8, v013AD5C0_0, 32;
    %movi 40, 0, 8;
    %muli 8, 100, 40;
    %load/v 48, v013AD5C0_0, 32;
    %movi 80, 0, 8;
    %load/v 88, v013ADA38_0, 32;
    %movi 120, 0, 8;
    %add 48, 88, 40;
    %div 8, 48, 40;
    %vpi_call 4 75 "$display", "ICache Hit Rate: %0d%%", T<8,40,u>;
T_0.0 ;
    %vpi_call 4 76 "$display", "----------------------------------------";
    %vpi_call 4 77 "$display", "DCache Hits:    %0d", v013AD1F8_0;
    %vpi_call 4 78 "$display", "DCache Misses:  %0d", v013ADAE8_0;
    %vpi_call 4 79 "$display", "DCache Writes:  %0d", v013ADB98_0;
    %load/v 8, v013AD1F8_0, 32;
    %mov 40, 0, 1;
    %load/v 41, v013ADAE8_0, 32;
    %mov 73, 0, 1;
    %add 8, 41, 33;
    %cmp/u 0, 8, 33;
    %jmp/0xz  T_0.2, 5;
    %load/v 8, v013AD1F8_0, 32;
    %movi 40, 0, 8;
    %muli 8, 100, 40;
    %load/v 48, v013AD1F8_0, 32;
    %movi 80, 0, 8;
    %load/v 88, v013ADAE8_0, 32;
    %movi 120, 0, 8;
    %add 48, 88, 40;
    %div 8, 48, 40;
    %vpi_call 4 81 "$display", "DCache Hit Rate: %0d%%", T<8,40,u>;
T_0.2 ;
    %vpi_call 4 82 "$display", "========================================\012";
    %end;
