TD_tb_riscv_soc_top_cached.display_stats ;
    %vpi_call 4 69 "$display", "========================================" {0 0 0};
    %vpi_call 4 70 "$display", "Cache Statistics at time %0t", $time {0 0 0};
    %vpi_call 4 71 "$display", "========================================" {0 0 0};
    %vpi_call 4 72 "$display", "ICache Hits:    %0d", v0x56929c34d460_0 {0 0 0};
    %vpi_call 4 73 "$display", "ICache Misses:  %0d", v0x56929c34d520_0 {0 0 0};
    %load/vec4 v0x56929c34d460_0;
    %load/vec4 v0x56929c34d520_0;
    %add;
    %cmpi/u 0, 0, 32;
    %flag_or 5, 4; GT is !LE
    %flag_inv 5;
    %jmp/0xz  T_0.0, 5;
    %load/vec4 v0x56929c34d460_0;
    %muli 100, 0, 32;
    %load/vec4 v0x56929c34d460_0;
    %load/vec4 v0x56929c34d520_0;
    %add;
    %div;
    %vpi_call 4 75 "$display", "ICache Hit Rate: %0d%%", S<0,vec4,u32> {1 0 0};
T_0.0 ;
    %vpi_call 4 76 "$display", "----------------------------------------" {0 0 0};
    %vpi_call 4 77 "$display", "DCache Hits:    %0d", v0x56929c34d160_0 {0 0 0};
    %vpi_call 4 78 "$display", "DCache Misses:  %0d", v0x56929c34d220_0 {0 0 0};
    %vpi_call 4 79 "$display", "DCache Writes:  %0d", v0x56929c34d2c0_0 {0 0 0};
    %load/vec4 v0x56929c34d160_0;
    %load/vec4 v0x56929c34d220_0;
    %add;
    %cmpi/u 0, 0, 32;
    %flag_or 5, 4; GT is !LE
    %flag_inv 5;
    %jmp/0xz  T_0.2, 5;
    %load/vec4 v0x56929c34d160_0;
    %muli 100, 0, 32;
    %load/vec4 v0x56929c34d160_0;
    %load/vec4 v0x56929c34d220_0;
    %add;
    %div;
    %vpi_call 4 81 "$display", "DCache Hit Rate: %0d%%", S<0,vec4,u32> {1 0 0};
T_0.2 ;
    %vpi_call 4 82 "$display", "========================================\012" {0 0 0};
    %end;
