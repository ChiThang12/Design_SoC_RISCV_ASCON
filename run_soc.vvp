S_0156C5C8 .scope task, "print_banner" "print_banner" 4 700, 4 700, S_0156B330;
 .timescale -9 -12;
TD_run_soc.print_banner ;
    %vpi_call 4 702 "$display", "\000";
    %vpi_call 4 703 "$display", "+=================================================================+";
    %vpi_call 4 704 "$display", "|   RISC-V SoC v3.0  --  Universal Debug Testbench               |";
    %vpi_call 4 705 "$display", "|   ICache 4KB | DCache 8KB | AXI4 Crossbar 2Mx4S | 100 MHz      |";
    %vpi_call 4 706 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 707 "$display", "|   Address Map:                                                  |";
    %vpi_call 4 708 "$display", "|     S0  IMEM     0x0000_0000 - 0x0000_FFFF  (64 KB)            |";
    %vpi_call 4 709 "$display", "|     S1  DMEM     0x1000_0000 - 0x1000_FFFF  (64 KB)            |";
    %vpi_call 4 710 "$display", "|     S2  ASCON    0x2000_0000 - 0x2000_0FFF  ( 4 KB)            |";
    %vpi_call 4 711 "$display", "|     S3  SoCCtrl  0x3000_0000 - 0x3000_0FFF  ( 4 KB)            |";
    %vpi_call 4 712 "$display", "|     --   other  -> DECERR (RDATA=0xDEAD_BEEF)                  |";
    %vpi_call 4 713 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 714 "$display", "|   LOG_LEVEL=%0d   TIMEOUT=%0d cyc   HALT_STABLE=%0d cyc          |", 3'sb010, 15'sb011101010011000, 7'sb0111100;
    %vpi_call 4 716 "$display", "+=================================================================+";
    %vpi_call 4 717 "$display", "\000";
    %end;
