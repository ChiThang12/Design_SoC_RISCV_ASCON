S_01D62BD0 .scope task, "print_banner" "print_banner" 4 1450, 4 1450, S_01D4FE98;
 .timescale -9 -12;
TD_run_soc.print_banner ;
    %vpi_call 4 1452 "$display", "\000";
    %vpi_call 4 1453 "$display", "+=================================================================+";
    %vpi_call 4 1454 "$display", "|   RISC-V SoC  +  ASCON IP  --  Debug Testbench  v5.2           |";
    %vpi_call 4 1455 "$display", "|   ICache | DCache | AXI4 Crossbar 3Mx5S | ascon_ip | 100MHz    |";
    %vpi_call 4 1456 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 1457 "$display", "|   Masters:  M0=ICache  M1=DCache  M2=DMA(via width_conv 64>32) |";
    %vpi_call 4 1458 "$display", "|   Address Map:                                                  |";
    %vpi_call 4 1459 "$display", "|     S0  IMEM     0x0000_0000 - 0x0000_1FFF  ( 8 KB, ROM)       |";
    %vpi_call 4 1460 "$display", "|     S1  DMEM     0x1000_0000 - 0x1000_1FFF  ( 8 KB, RAM)       |";
    %vpi_call 4 1461 "$display", "|     S2  ASCON    0x2000_0000 - 0x2000_0FFF  ( 4 KB)            |";
    %vpi_call 4 1462 "$display", "|     S3  SoCCtrl  0x3000_0000 - 0x3000_0FFF  ( 4 KB)            |";
    %vpi_call 4 1463 "$display", "|     S4  CLINT    0x4000_0000 - 0x4000_FFFF  (64 KB)            |";
    %vpi_call 4 1464 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 1465 "$display", "|   Instances in soc_top:                                         |";
    %vpi_call 4 1466 "$display", "|     u_cpu  u_icache  u_dcache  u_crossbar  u_imem  u_dmem       |";
    %vpi_call 4 1467 "$display", "|     u_ascon  u_width_conv  u_clint  u_soc_ctrl                  |";
    %vpi_call 4 1468 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 1469 "$display", "|   LOG_LEVEL=%0d   TIMEOUT=%0d cyc   HALT_STABLE=%0d cyc         |", 3'sb010, 12'sb011111010000, 7'sb0111100;
    %vpi_call 4 1471 "$display", "+=================================================================+";
    %vpi_call 4 1472 "$display", "\000";
    %end;
