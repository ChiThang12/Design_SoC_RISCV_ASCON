S_018D0F68 .scope task, "print_banner" "print_banner" 4 1300, 4 1300, S_018C7778;
 .timescale -9 -12;
TD_run_soc.print_banner ;
    %vpi_call 4 1302 "$display", "\000";
    %vpi_call 4 1303 "$display", "+=================================================================+";
    %vpi_call 4 1304 "$display", "|   RISC-V SoC  +  ASCON IP  --  Debug Testbench  v5.0           |";
    %vpi_call 4 1305 "$display", "|   ICache | DCache | AXI4 Crossbar 3Mx5S | ascon_ip | 100MHz    |";
    %vpi_call 4 1306 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 1307 "$display", "|   Masters:  M0=ICache  M1=DCache  M2=DMA(via width_conv 64>32) |";
    %vpi_call 4 1308 "$display", "|   Address Map:                                                  |";
    %vpi_call 4 1309 "$display", "|     S0  IMEM     0x0000_0000 - 0x0000_FFFF  (64 KB, ROM)       |";
    %vpi_call 4 1310 "$display", "|     S1  DMEM     0x1000_0000 - 0x1000_FFFF  (64 KB, RAM)       |";
    %vpi_call 4 1311 "$display", "|     S2  ASCON    0x2000_0000 - 0x2000_0FFF  ( 4 KB)            |";
    %vpi_call 4 1312 "$display", "|     S3  SoCCtrl  0x3000_0000 - 0x3000_0FFF  ( 4 KB)            |";
    %vpi_call 4 1313 "$display", "|     S4  CLINT    0x4000_0000 - 0x4000_FFFF  (64 KB)            |";
    %vpi_call 4 1314 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 1315 "$display", "|   Instances in soc_top:                                         |";
    %vpi_call 4 1316 "$display", "|     u_cpu  u_icache  u_dcache  u_crossbar  u_imem  u_dmem       |";
    %vpi_call 4 1317 "$display", "|     u_ascon  u_width_conv  u_clint  u_soc_ctrl                  |";
    %vpi_call 4 1318 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 1319 "$display", "|   LOG_LEVEL=%0d   TIMEOUT=%0d cyc   HALT_STABLE=%0d cyc         |", 3'sb010, 19'sb0110000110101000000, 7'sb0111100;
    %vpi_call 4 1321 "$display", "+=================================================================+";
    %vpi_call 4 1322 "$display", "\000";
    %end;
