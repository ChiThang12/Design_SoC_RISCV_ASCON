S_018C3F18 .scope task, "print_banner" "print_banner" 4 1400, 4 1400, S_018BA1D8;
 .timescale -9 -12;
TD_run_soc.print_banner ;
    %vpi_call 4 1402 "$display", "\000";
    %vpi_call 4 1403 "$display", "+=================================================================+";
    %vpi_call 4 1404 "$display", "|   RISC-V SoC  +  ASCON IP  --  Debug Testbench  v5.1-DBG      |";
    %vpi_call 4 1405 "$display", "|   ICache | DCache | AXI4 Crossbar 3Mx5S | ascon_ip | 100MHz    |";
    %vpi_call 4 1406 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 1407 "$display", "|   Masters:  M0=ICache  M1=DCache  M2=DMA(via width_conv 64>32) |";
    %vpi_call 4 1408 "$display", "|   Address Map:                                                  |";
    %vpi_call 4 1409 "$display", "|     S0  IMEM     0x0000_0000 - 0x0000_FFFF  (64 KB, ROM)       |";
    %vpi_call 4 1410 "$display", "|     S1  DMEM     0x1000_0000 - 0x1000_FFFF  (64 KB, RAM)       |";
    %vpi_call 4 1411 "$display", "|     S2  ASCON    0x2000_0000 - 0x2000_0FFF  ( 4 KB)            |";
    %vpi_call 4 1412 "$display", "|     S3  SoCCtrl  0x3000_0000 - 0x3000_0FFF  ( 4 KB)            |";
    %vpi_call 4 1413 "$display", "|     S4  CLINT    0x4000_0000 - 0x4000_FFFF  (64 KB)            |";
    %vpi_call 4 1414 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 1415 "$display", "|   Instances in soc_top:                                         |";
    %vpi_call 4 1416 "$display", "|     u_cpu  u_icache  u_dcache  u_crossbar  u_imem  u_dmem       |";
    %vpi_call 4 1417 "$display", "|     u_ascon  u_width_conv  u_clint  u_soc_ctrl                  |";
    %vpi_call 4 1418 "$display", "+-----------------------------------------------------------------+";
    %vpi_call 4 1419 "$display", "|   LOG_LEVEL=%0d   TIMEOUT=%0d cyc   HALT_STABLE=%0d cyc         |", 3'sb010, 19'sb0110000110101000000, 7'sb0111100;
    %vpi_call 4 1421 "$display", "+=================================================================+";
    %vpi_call 4 1422 "$display", "\000";
    %end;
