        <mxCell id="l9BzlZGCTBzslpsVhpJj-8" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 data-start=&quot;3068&quot; data-end=&quot;3095&quot;&gt; Câu chốt (nên nhớ kỹ)&lt;/h1&gt;&lt;blockquote data-start=&quot;3097&quot; data-end=&quot;3268&quot;&gt;&lt;p data-start=&quot;3099&quot; data-end=&quot;3155&quot;&gt;🔥 &lt;strong data-start=&quot;3102&quot; data-end=&quot;3155&quot;&gt;Không gian địa chỉ là “bảng điều khiển” của slave&lt;/strong&gt;&lt;/p&gt;&lt;p data-start=&quot;3160&quot; data-end=&quot;3225&quot;&gt;🔥 &lt;strong data-start=&quot;3163&quot; data-end=&quot;3225&quot;&gt;Offset = cách CPU nói “tôi muốn truy cập cái gì bên trong”&lt;/strong&gt;&lt;/p&gt;&lt;p data-start=&quot;3230&quot; data-end=&quot;3268&quot;&gt;🔥 &lt;strong data-start=&quot;3233&quot; data-end=&quot;3268&quot;&gt;Không phải để tạo thêm register&lt;/strong&gt;&lt;/p&gt;&lt;p data-start=&quot;3230&quot; data-end=&quot;3268&quot;&gt;&lt;strong data-start=&quot;3233&quot; data-end=&quot;3268&quot;&gt;&lt;br&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p data-start=&quot;3230&quot; data-end=&quot;3268&quot;&gt;&lt;strong data-start=&quot;3233&quot; data-end=&quot;3268&quot;&gt;&lt;br&gt;&lt;/strong&gt;&lt;/p&gt;&lt;/blockquote&gt;" vertex="1">
