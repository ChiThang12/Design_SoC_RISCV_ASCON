        <mxCell id="l9BzlZGCTBzslpsVhpJj-9" parent="1" style="text;whiteSpace=wrap;html=1;" value="🔥 &lt;strong data-start=&quot;1751&quot; data-end=&quot;1779&quot;&gt;Address = “gõ cửa” slave&lt;/strong&gt;&lt;br data-start=&quot;1779&quot; data-end=&quot;1782&quot;&gt;&#xa;🔥 &lt;strong data-start=&quot;1787&quot; data-end=&quot;1828&quot;&gt;Offset = “chỉ tay vào ngăn bên trong”&lt;/strong&gt;&lt;br data-start=&quot;1828&quot; data-end=&quot;1831&quot;&gt;&#xa;🔥 &lt;strong data-start=&quot;1836&quot; data-end=&quot;1865&quot;&gt;Data = “thứ được đưa vào”&lt;/strong&gt;" vertex="1">
